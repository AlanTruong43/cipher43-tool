{
    "manifest_version": 3,
    "name": "Cipher 43 Tool",
    "version": "2.0.0",
    "description": "Cipher 43 automation bridge — chạy tool trực tiếp từ trình duyệt",

    "permissions": ["tabs", "storage"],

    "host_permissions": [
        "http://127.0.0.1:*/*"
    ],

    "action": {
        "default_popup": "popup.html",
        "default_title": "Cipher 43 Tool"
    },

    "background": {
        "service_worker": "background.js"
    },

    "icons": {
        "16":  "icons/icon16.png",
        "48":  "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
