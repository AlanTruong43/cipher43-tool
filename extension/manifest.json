{
    "manifest_version": 3,
    "name": "Cipher 43 Tool",
    "version": "1.0.0",
    "description": "Tự động inject debug port vào window.__c43_port",

    "permissions": ["tabs"],

    "host_permissions": [
        "http://127.0.0.1:*/*"
    ],

    "action": {
        "default_popup": "popup.html",
        "default_title": "Cipher 43 — Debug Port"
    },

    "background": {
        "service_worker": "background.js"
    },

    "icons": {
        "16":  "icons/icon16.png",
        "48":  "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
